# 管理員登入帳號與密碼（使用者在登入頁輸入這組）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password-here

# 寫入 cookie 的 token（必須與 ADMIN_PASSWORD 不同，使用隨機長字串）
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=your-random-secret-token-here

# Supabase（只放 server side secret，不要加 NEXT_PUBLIC 前綴）
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
SUPABASE_STORAGE_BUCKET=akas-assets

# Resend — 用於後台回覆聯絡表單來信
# 申請帳號：https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 寄件者顯示名稱與地址（需在 Resend 驗證網域，測試可用 onboarding@resend.dev）
RESEND_FROM=艾卡斯管理顧問 <onboarding@resend.dev>
